 implementation(platform("org.http4k:http4k-bom:6.53.0.0"))

&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#75715e"&gt;// for the Universal LLM adapter (uses the OpenAI fake)
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; implementation(&lt;span style="color:#e6db74"&gt;&amp;#34;org.http4k:http4k-ai-llm-github&amp;#34;&lt;/span&gt;)
